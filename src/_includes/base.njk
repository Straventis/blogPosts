<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title or "Straventis" }} | Straventis</title>
<meta name="description" content="{{ description or 'Straventis Advisory Group' }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#F1EFEA;
    --surface:#FAF9F6;
    --ink:#211F1C;
    --ink-soft:#6E6A62;
    --line:#DCD8CF;
    --accent:#3E5C55;
    --accent-soft:#DEE6E2;
    --logo-mark:#F1EFEA;
    --mono: 'JetBrains Mono', monospace;
    --sans: 'Inter', sans-serif;
    --display: 'Space Grotesk', sans-serif;
  }

  html[data-theme="dark"]{
    --bg:#18191B;
    --surface:#212225;
    --ink:#EDEBE5;
    --ink-soft:#8F8B82;
    --line:#2E2F2F;
    --accent:#75A594;
    --accent-soft:#22322C;
    --logo-mark:#18191B;
  }

  *{ box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  body{
    margin:0;
    background:var(--bg);
    color:var(--ink);
    font-family:var(--sans);
    -webkit-font-smoothing:antialiased;
    transition:background 0.25s ease, color 0.25s ease;
  }
  a{ color:inherit; }
  :focus-visible{ outline:2px solid var(--accent); outline-offset:3px; }

  .wrap{ max-width:760px; margin:0 auto; padding:0 28px; }
  .wrap.wrap-wide{ max-width:940px; }

  /* ---------- top bar ---------- */
  .topbar{ padding:28px 0; border-bottom:1px solid var(--line); }
  .topbar .wrap{ display:flex; align-items:center; justify-content:space-between; }
  .brandmark{ display:flex; align-items:center; gap:10px; text-decoration:none; }
  .brandmark .word{
    font-family:var(--mono); font-size:13px; letter-spacing:0.08em;
    color:var(--ink-soft); text-transform:uppercase;
  }
  .brandmark .word b{ color:var(--ink); font-weight:600; }
  .nav-links{ display:flex; gap:24px; align-items:center; }
  .nav-links a{
    font-family:var(--mono); font-size:13px; text-transform:uppercase;
    letter-spacing:0.06em; color:var(--ink-soft); text-decoration:none;
  }
  .nav-links a:hover{ color:var(--accent); }

  .theme-toggle{
    display:flex; align-items:center; justify-content:center;
    width:34px; height:34px; border-radius:50%;
    border:1px solid var(--line); background:var(--surface);
    cursor:pointer; color:var(--ink-soft);
    transition:background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .theme-toggle:hover{ color:var(--ink); border-color:var(--accent); }
  .theme-toggle svg{ width:16px; height:16px; }
  .theme-toggle .icon-moon{ display:none; }
  html[data-theme="dark"] .theme-toggle .icon-sun{ display:none; }
  html[data-theme="dark"] .theme-toggle .icon-moon{ display:block; }

  /* ---------- page content ---------- */
  main{ padding:56px 0 80px; }

  .eyebrow{
    font-family:var(--mono); font-size:12px; letter-spacing:0.12em;
    text-transform:uppercase; color:var(--accent); margin:0 0 14px;
  }
  h1.page-title{
    font-family:var(--display); font-weight:600;
    font-size:clamp(30px, 5vw, 44px); line-height:1.1;
    letter-spacing:-0.02em; margin:0 0 12px;
  }
  .page-subtitle{
    font-size:16px; color:var(--ink-soft); margin:0 0 28px; max-width:520px;
  }
  .page-meta{
    font-family:var(--mono); font-size:12px; color:var(--ink-soft);
    margin:0 0 40px;
  }
  .last-updated{
    font-family:var(--mono); font-size:11px; color:var(--ink-soft);
    opacity:0.75; margin:0 0 28px;
  }

  main :is(h2, h3){
    font-family:var(--display); font-weight:600; letter-spacing:-0.01em;
    margin-top:36px; margin-bottom:14px;
  }
  main h2{ font-size:24px; }
  main h3{ font-size:19px; }
  main p{ font-size:16px; line-height:1.7; color:var(--ink); margin:0 0 20px; }
  main p.lead{ font-size:18px; color:var(--ink-soft); }
  main a{ color:var(--accent); text-decoration:underline; text-underline-offset:2px; }
  main ul, main ol{ font-size:16px; line-height:1.7; margin:0 0 20px; padding-left:22px; }
  main li{ margin-bottom:8px; }
  html[data-font="small"]{ --reading-font-size: 14px; --reading-line-height: 1.6; }
  html[data-font="default"]{ --reading-font-size: 16px; --reading-line-height: 1.7; }
  html[data-font="large"]{ --reading-font-size: 18px; --reading-line-height: 1.75; }
  html[data-font="xlarge"]{ --reading-font-size: 21px; --reading-line-height: 1.8; }

  html[data-width="narrow"]{ --reading-width: 560px; }
  html[data-width="normal"]{ --reading-width: 700px; }
  html[data-width="wide"]{ --reading-width: 880px; }

  .post-content{
    max-width: var(--reading-width, 700px);
    margin: 0 auto;
    transition: max-width 0.2s ease;
  }
  .post-content p{
    font-size: var(--reading-font-size, 16px) !important;
    line-height: var(--reading-line-height, 1.7) !important;
  }
  .post-content li{
    font-size: var(--reading-font-size, 16px) !important;
  }

  .reading-controls{
    display:flex; gap:20px; flex-wrap:wrap; align-items:center;
    margin:0 0 32px; padding:14px 16px; border:1px solid var(--line);
    border-radius:10px; background:var(--surface);
  }
  .reading-controls .group{ display:flex; gap:6px; align-items:center; }
  .reading-controls .group-label{
    font-family:var(--mono); font-size:10px; text-transform:uppercase;
    letter-spacing:0.06em; color:var(--ink-soft); margin-right:4px;
  }
  .reading-controls button{
    font-family:var(--mono); font-size:12px; padding:5px 11px;
    border-radius:16px; border:1px solid var(--line); background:var(--bg);
    color:var(--ink-soft); cursor:pointer;
  }
  .reading-controls button:hover{ border-color:var(--accent); color:var(--ink); }
  .reading-controls button.active{
    background:var(--accent); border-color:var(--accent); color:var(--bg);
  }

  main img{ max-width:100%; border-radius:10px; margin:24px 0; display:block; }

  .media-row{
    display:flex; gap:28px; align-items:flex-start; margin:32px 0;
  }
  .media-row img{
    width:42%; flex-shrink:0; margin:0; border-radius:10px;
  }
  .media-row .media-text{ flex:1; }
  .media-row .media-text p{ margin:0 0 16px; font-size:16px; line-height:1.7; }
  .media-row .media-text p:last-child{ margin-bottom:0; }

  @media (max-width:640px){
    .media-row{ flex-direction:column; }
    .media-row img{ width:100%; }
  }
  main blockquote{
    margin:24px 0; padding:4px 0 4px 20px; border-left:3px solid var(--accent);
    color:var(--ink-soft); font-style:italic;
  }
  main code{
    font-family:var(--mono); font-size:14px; background:var(--surface);
    border:1px solid var(--line); padding:2px 6px; border-radius:4px;
  }
  main pre{
    background:var(--surface); border:1px solid var(--line); border-radius:10px;
    padding:16px; overflow-x:auto;
  }
  main pre code{ border:none; padding:0; background:none; }

  /* ---------- footer ---------- */
  footer{
    padding:40px 0 60px; text-align:center;
    font-family:var(--mono); font-size:12px; color:var(--ink-soft);
    border-top:1px solid var(--line);
  }

  @media (prefers-reduced-motion: reduce){ html{ scroll-behavior:auto; } }
</style>
</head>
<body>

<div class="topbar">
  <div class="wrap">
    <a class="brandmark" href="/">
      <svg width="22" height="22" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="40" height="40" rx="10" fill="var(--accent)"/>
        <path d="M9 25L15.5 18L20.5 22.5L31 11" stroke="var(--logo-mark)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="31" cy="11" r="2.6" fill="var(--logo-mark)"/>
      </svg>
      <span class="word"><b>Straventis</b></span>
    </a>
    <div class="nav-links">
      <a href="/">Blog</a>
      <a href="https://straventis.com">Home</a>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode" type="button">
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1111.2 3a7 7 0 009.8 9.8z"/></svg>
      </button>
    </div>
  </div>
</div>

<main>
  <div class="wrap{% if wideLayout %} wrap-wide{% endif %}">
    {{ content | safe }}
  </div>
</main>

<footer>
  Straventis Advisory Group
  <br>
  <span style="opacity:0.7;">Site last updated {{ buildTime | readableDateTime }}</span>
</footer>

<script>
  (function(){
    var root = document.documentElement;
    var btn = document.getElementById('theme-toggle');

    function getStored(){
      try { return localStorage.getItem('straventis-theme-override'); } catch(e){ return null; }
    }
    function setStored(val){
      try { localStorage.setItem('straventis-theme-override', val); } catch(e){}
    }
    function timeBasedTheme(){
      var hour = new Date().getHours();
      return (hour >= 19 || hour < 7) ? 'dark' : 'light';
    }
    function applyTheme(){
      var override = getStored();
      root.setAttribute('data-theme', override || timeBasedTheme());
    }

    applyTheme();
    setInterval(function(){ if (!getStored()) applyTheme(); }, 5 * 60 * 1000);

    btn.addEventListener('click', function(){
      var next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      setStored(next);
    });
  })();
</script>

</body>
</html>
